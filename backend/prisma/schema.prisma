generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Global Settings ─────────────────────────────────

model Setting {
  key       String   @id
  value     Json     @default("{}")
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ─── Branch ──────────────────────────────────────────

model Branch {
  id            Int      @id @default(autoincrement())
  name          String
  code          String   @unique
  address       String?
  phone         String?
  email         String?
  taxConfig     Json     @default("{}")
  receiptHeader String?
  receiptFooter String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users              User[]
  inventory          Inventory[]
  inventoryMovements InventoryMovement[]
  transfersFrom      StockTransfer[]     @relation("TransferFrom")
  transfersTo        StockTransfer[]     @relation("TransferTo")
  sales              Sale[]
  returns            Return[]
  posSessions        PosSession[]
  heldTransactions   HeldTransaction[]
  journalEntries     JournalEntry[]
  expenses           Expense[]
  attendance         Attendance[]
  upiPaymentIntents  UpiPaymentIntent[]
  printerProfiles    PrinterProfile[]
  auditLogs          AuditLog[]
  giftVouchers       GiftVoucher[]

  @@map("branches")
}

// ─── Audit log ───────────────────────────────────────
// Append-only trail of sensitive operations (refunds, refund-method overrides,
// commission reversals, loyalty adjustments, bill edits, voucher ops…). Every
// entry records who, when, what changed (data.original / data.updated), and why.
model AuditLog {
  id         Int      @id @default(autoincrement())
  branchId   Int?
  userId     Int?
  action     String   // e.g. 'return.created', 'refund.method_overridden', 'commission.reversed'
  entityType String   // 'sale' | 'return' | 'commission' | 'loyalty' | 'payment' | …
  entityId   String?  // id of the affected entity (string so it's type-agnostic)
  reason     String?
  data       Json?    // { original?, updated?, … } or any structured detail
  createdAt  DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([entityType, entityId])
  @@index([branchId, createdAt])
  @@map("audit_logs")
}

// ─── Printing (barcode label printers) ───────────────

model PrinterProfile {
  id           Int      @id @default(autoincrement())
  branchId     Int
  name         String
  vendor       String   @default("generic")
  model        String?
  driver       String   // 'tspl' | 'zpl' | 'epl2' | 'escpos-label' | 'pdf'
  transport    String   // 'tcp' | 'usb-lp' | 'cups' | 'win-spool' | 'browser'
  connection   Json     @default("{}")
  dpi          Int      @default(203)
  maxWidthMm   Float    @default(108)
  capabilities Json     @default("{}")
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch    Branch          @relation(fields: [branchId], references: [id])
  templates LabelTemplate[]

  @@index([branchId])
  @@map("printer_profiles")
}

model LabelTemplate {
  id               Int      @id @default(autoincrement())
  printerProfileId Int
  name             String
  widthMm          Float
  heightMm         Float
  gapMm            Float    @default(2)
  density          Int      @default(8)
  speed            Int      @default(4)
  elements         Json     @default("[]")
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  printer PrinterProfile @relation(fields: [printerProfileId], references: [id], onDelete: Cascade)

  @@index([printerProfileId])
  @@map("label_templates")
}

// ─── User / Employee ─────────────────────────────────

enum UserRole {
  owner
  manager
  cashier
  staff
}

model User {
  id             Int      @id @default(autoincrement())
  branchId       Int
  email          String   @unique
  passwordHash   String
  firstName      String
  lastName       String
  phone          String?
  role           UserRole @default(staff)
  commissionRate Decimal  @default(0) @db.Decimal(5, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch             Branch              @relation(fields: [branchId], references: [id])
  sales              Sale[]
  returns            Return[]
  posSessions        PosSession[]
  heldTransactions   HeldTransaction[]
  inventoryMovements InventoryMovement[]
  transfersCreated   StockTransfer[]     @relation("TransferCreator")
  transfersApproved  StockTransfer[]     @relation("TransferApprover")
  journalEntries     JournalEntry[]
  expensesCreated    Expense[]           @relation("ExpenseCreator")
  expensesApproved   Expense[]           @relation("ExpenseApprover")
  attendance         Attendance[]
  commissions        Commission[]
  upiPaymentIntents  UpiPaymentIntent[]
  agentSaleItems     SaleItem[]          @relation("SaleItemAgent")
  vendorPayments     VendorPayment[]
  auditLogs          AuditLog[]

  @@map("users")
}

// ─── Brand ───────────────────────────────────────────

model Brand {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  products Product[]

  @@map("brands")
}

// ─── Category ────────────────────────────────────────

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  slug      String     @unique
  parentId  Int?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

// ─── Color ───────────────────────────────────────────
//
// Preset color palette used by the variant editors so cashiers/managers
// pick from a consistent list instead of free-typing "navy" / "Navy" /
// "NAVY" etc. `product_variants.color` is intentionally still a string —
// it stores the chosen color NAME (the human-readable label on receipts,
// stickers, POS) rather than a foreign key, which keeps old variants
// working without a data migration.
model Color {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  // Optional hex value (e.g. "#0F172A") used to render a swatch dot next
  // to the name in pickers. Safe to leave null for uncommon shades.
  hex       String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("colors")
}

// ─── Product ─────────────────────────────────────────

model Product {
  id          Int      @id @default(autoincrement())
  brandId     Int
  categoryId  Int
  name        String
  slug        String   @unique
  description String?
  // §13.3 — MRP is the printed list price; basePrice is the effective Sale Price
  // (auto-calculated as MRP − 10% at entry). Both are printed on the barcode label.
  mrp          Decimal? @db.Decimal(10, 2)
  basePrice    Decimal  @db.Decimal(10, 2)
  costPrice    Decimal  @db.Decimal(10, 2)
  landingPrice Decimal? @db.Decimal(10, 2)
  // GST is split into CGST + SGST per Indian tax rules. For non-clothing
  // verticals these can both be 0. Effective rate the POS sees = cgst + sgst.
  hsnCode      String?  @db.VarChar(10)
  cgstRate     Decimal  @default(9) @db.Decimal(5, 2)
  sgstRate     Decimal  @default(9) @db.Decimal(5, 2)
  // When true (the Indian retail convention), basePrice is the MRP — tax is
  // already extracted from inside it. When false, tax is added on top at POS.
  priceIncludesTax Boolean @default(true)
  // Sale-policy flags. `nonReturnable` blocks both refund-returns and exchanges
  // (e.g. clearance/sale/defective goods). `exchangeOnly` allows an exchange but
  // blocks a refund-return. The POS enforces these when goods come back.
  nonReturnable Boolean @default(false)
  exchangeOnly  Boolean @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand    Brand            @relation(fields: [brandId], references: [id])
  category Category         @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]
  offers   OfferProduct[]

  @@map("products")
}

model ProductVariant {
  id            Int      @id @default(autoincrement())
  productId     Int
  sku           String   @unique
  size          String
  color         String
  barcode       String   @unique
  // §13.3 — per-variant MRP override. Falls back to the product's MRP when null.
  // Sale Price (priceOverride) auto-fills to mrpOverride − 10% at entry, editable.
  mrpOverride   Decimal? @db.Decimal(10, 2)
  priceOverride Decimal? @db.Decimal(10, 2)
  costOverride  Decimal? @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  // §2.4 — Clearance (dead-stock liquidation). When flagged, clearancePrice is
  // the fixed selling price and ALL counter discounts lock to zero; managed
  // backend-only, never at POS.
  clearanceFlag  Boolean  @default(false)
  clearancePrice Decimal? @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  product            Product             @relation(fields: [productId], references: [id])
  inventory          Inventory[]
  inventoryMovements InventoryMovement[]
  saleItems          SaleItem[]
  returnItems        ReturnItem[]
  stockTransferItems StockTransferItem[]
  offers             OfferVariant[]

  @@map("product_variants")
}

// ─── Inventory ───────────────────────────────────────

model Inventory {
  id            Int      @id @default(autoincrement())
  variantId     Int
  branchId      Int
  quantity      Int      @default(0)
  minStockLevel Int      @default(5)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  variant ProductVariant @relation(fields: [variantId], references: [id])
  branch  Branch         @relation(fields: [branchId], references: [id])

  @@unique([variantId, branchId])
  @@map("inventory")
}

enum MovementType {
  purchase
  sale
  return
  transfer_in
  transfer_out
  adjustment
}

enum InventoryPaymentMode {
  cash
  credit
}

model InventoryMovement {
  id            Int          @id @default(autoincrement())
  variantId     Int
  branchId      Int
  type          MovementType
  quantity      Int
  // Per-unit cost paid to vendor at time of purchase. Only meaningful for
  // type=purchase movements; null for sales / transfers / adjustments.
  unitCost      Decimal?     @db.Decimal(10, 2)
  // CASH = paid in full at receipt; CREDIT = recorded as accounts-payable
  // and settled later via VendorPayment rows. Null for non-purchase types.
  paymentMode   InventoryPaymentMode?
  dueDate       DateTime?
  referenceId   Int?
  referenceType String?
  notes         String?
  lotCode       String?
  createdBy     Int
  vendorId      Int?
  createdAt     DateTime     @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id])
  branch  Branch         @relation(fields: [branchId], references: [id])
  user    User           @relation(fields: [createdBy], references: [id])
  vendor  Vendor?        @relation(fields: [vendorId], references: [id])

  @@map("inventory_movements")
}

// Subsequent payments against credit purchases — each row reduces the
// vendor's outstanding balance. We don't try to allocate a payment to
// specific movements (would force the cashier into bookkeeping); the
// balance is just (sum of credit purchase costs) − (sum of payments).
model VendorPayment {
  id          Int      @id @default(autoincrement())
  vendorId    Int
  amount      Decimal  @db.Decimal(10, 2)
  method      String   // cash | bank_transfer | upi | cheque
  reference   String?  // cheque number, UTR, txn id
  notes       String?
  paymentDate DateTime
  createdBy   Int
  createdAt   DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])
  user   User   @relation(fields: [createdBy], references: [id])

  @@map("vendor_payments")
}

// ─── Vendor ──────────────────────────────────────────

model Vendor {
  id            Int      @id @default(autoincrement())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  gstNumber     String?
  paymentTerms  String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inventoryMovements InventoryMovement[]
  payments           VendorPayment[]

  @@map("vendors")
}

enum TransferStatus {
  pending
  in_transit
  completed
  cancelled
}

model StockTransfer {
  id           Int            @id @default(autoincrement())
  fromBranchId Int
  toBranchId   Int
  status       TransferStatus @default(pending)
  createdBy    Int
  approvedBy   Int?
  createdAt    DateTime       @default(now())
  completedAt  DateTime?

  fromBranch Branch              @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranch   Branch              @relation("TransferTo", fields: [toBranchId], references: [id])
  creator    User                @relation("TransferCreator", fields: [createdBy], references: [id])
  approver   User?               @relation("TransferApprover", fields: [approvedBy], references: [id])
  items      StockTransferItem[]

  @@map("stock_transfers")
}

model StockTransferItem {
  id               Int @id @default(autoincrement())
  transferId       Int
  variantId        Int
  quantitySent     Int
  quantityReceived Int @default(0)

  transfer StockTransfer  @relation(fields: [transferId], references: [id])
  variant  ProductVariant @relation(fields: [variantId], references: [id])

  @@map("stock_transfer_items")
}

// ─── Sales & POS ─────────────────────────────────────

enum SaleStatus {
  completed
  returned
  partially_returned
  void
}

enum SaleChannel {
  walkin
  online
}

model Sale {
  id                   Int        @id @default(autoincrement())
  branchId             Int
  customerId           Int?
  userId               Int
  saleNumber           String     @unique
  // Client-generated idempotency key (UUID). Every checkout — online or an
  // offline bill replayed on sync — carries one. A second checkout with the
  // same key returns the existing sale instead of creating a duplicate, so a
  // retry, double-tap, or re-sync can never double-bill. NULL for legacy rows.
  clientRef            String?    @unique
  // Sales channel drives the bill-number prefix (walk-in W-0001 vs online O-0001).
  // Prefixes themselves are configurable in Settings; the channel is the stable key.
  channel              SaleChannel @default(walkin)
  status               SaleStatus @default(completed)
  subtotal             Decimal    @db.Decimal(10, 2)
  taxAmount            Decimal    @db.Decimal(10, 2)
  discountAmount       Decimal    @default(0) @db.Decimal(10, 2)
  // §12 — itemized discount breakup for the Sales bill-breakup view. These split
  // the consolidated `discountAmount` for transparency; totals math is unchanged.
  manualDiscountAmount  Decimal   @default(0) @db.Decimal(10, 2)
  specialDiscountAmount Decimal   @default(0) @db.Decimal(10, 2)
  loyaltyDiscountAmount Decimal   @default(0) @db.Decimal(10, 2)
  total                Decimal    @db.Decimal(10, 2)
  loyaltyPointsEarned  Int        @default(0)
  loyaltyPointsRedeemed Int       @default(0)
  // When this sale settled part of its value with an exchange credit (goods
  // returned at the counter against the new purchase), the credited amount is
  // stored here and `exchangeReturnId` points at the originating Return.
  // sale.total stays the full new-items value (correct GST); the customer's
  // recorded payments cover only (total − exchangeCreditAmount).
  exchangeCreditAmount Decimal?   @default(0) @db.Decimal(10, 2)
  exchangeReturnId     Int?
  notes                String?
  createdAt            DateTime   @default(now())

  branch   Branch     @relation(fields: [branchId], references: [id])
  customer Customer?  @relation(fields: [customerId], references: [id])
  user     User       @relation(fields: [userId], references: [id])
  items    SaleItem[]
  payments Payment[]
  returns  Return[]
  commissions Commission[]
  loyaltyTransactions LoyaltyTransaction[]
  voucherRedemptions VoucherRedemption[]
  upiPaymentIntent UpiPaymentIntent?

  @@index([branchId, createdAt])
  @@map("sales")
}

model SaleItem {
  id                 Int     @id @default(autoincrement())
  saleId             Int
  variantId          Int
  quantity           Int
  unitPrice          Decimal @db.Decimal(10, 2)
  discount           Decimal @default(0) @db.Decimal(10, 2)
  taxAmount          Decimal @db.Decimal(10, 2)
  total              Decimal @db.Decimal(10, 2)
  returnedQuantity   Int     @default(0)
  offerId            Int?
  effectiveUnitPrice Decimal? @db.Decimal(10, 2)
  // §2.3 — Owner Discretion Discount (₹) applied to this line, authorised by
  // the Owner PIN at checkout. Stored distinctly (not merged into `discount`)
  // so the bill breakup / reports can show it as its own line.
  ownerDiscretionDiscount Decimal @default(0) @db.Decimal(10, 2)
  agentId            Int?
  // Per-bill "sold as-is" flag the cashier can set at checkout (clearance,
  // defective, final-sale goods) even when the product itself is returnable.
  // Returns are blocked if this OR the product's nonReturnable flag is set.
  nonReturnable      Boolean @default(false)

  sale        Sale           @relation(fields: [saleId], references: [id])
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  returnItems ReturnItem[]
  offer       Offer?         @relation(fields: [offerId], references: [id])
  agent       User?          @relation("SaleItemAgent", fields: [agentId], references: [id])

  @@map("sale_items")
}

// ─── Offers / Promotions ─────────────────────────────

enum OfferType {
  percentage           // X% off every unit
  flat                 // Rs. X off every unit
  buy_x_get_y_free     // BOGO: buy X units, Y are free (cheapest free)
  buy_x_get_y_percent  // Buy X units, get Y% off the whole line
  bundle               // Fixed total price for X units
}

model Offer {
  id           Int       @id @default(autoincrement())
  name         String                        // "Summer Sale 20%"
  description  String?
  type         OfferType
  percentValue Decimal?  @db.Decimal(5, 2)   // percentage / buy_x_get_y_percent
  flatValue    Decimal?  @db.Decimal(10, 2)  // flat / bundle total
  buyQty       Int?                          // BOGO / bundle threshold
  getQty       Int?                          // BOGO free/discount count
  priority     Int       @default(0)         // higher wins when multiple apply
  isActive     Boolean   @default(true)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  products  OfferProduct[]
  variants  OfferVariant[]
  saleItems SaleItem[]

  @@map("offers")
}

model OfferProduct {
  offerId   Int
  productId Int
  createdAt DateTime @default(now())

  offer   Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([offerId, productId])
  @@map("offer_products")
}

model OfferVariant {
  offerId   Int
  variantId Int
  createdAt DateTime @default(now())

  offer   Offer          @relation(fields: [offerId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([offerId, variantId])
  @@map("offer_variants")
}

enum PaymentMethod {
  cash
  card
  upi
  voucher
}

// ─── Gift vouchers ───────────────────────────────────
// Stored-value vouchers redeemed as a tender at checkout. Partial redemption is
// supported via `balance`; each use is logged in VoucherRedemption. A voucher
// refund (returning a voucher-paid sale) re-credits the balance.
enum VoucherStatus {
  active
  redeemed  // balance exhausted
  expired
  cancelled
}

model GiftVoucher {
  id           Int           @id @default(autoincrement())
  code         String        @unique
  initialValue Decimal       @db.Decimal(10, 2)
  balance      Decimal       @db.Decimal(10, 2)
  status       VoucherStatus @default(active)
  expiresAt    DateTime?
  customerId   Int? // optionally issued to a specific customer
  branchId     Int
  issuedBy     Int
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  customer    Customer?           @relation(fields: [customerId], references: [id])
  branch      Branch              @relation(fields: [branchId], references: [id])
  redemptions VoucherRedemption[]

  @@map("gift_vouchers")
}

model VoucherRedemption {
  id        Int      @id @default(autoincrement())
  voucherId Int
  saleId    Int?
  amount    Decimal  @db.Decimal(10, 2) // positive = redeemed, negative = re-credited on refund
  createdAt DateTime @default(now())

  voucher GiftVoucher @relation(fields: [voucherId], references: [id])
  sale    Sale?       @relation(fields: [saleId], references: [id])

  @@map("voucher_redemptions")
}

enum PaymentStatus {
  pending
  completed
  refunded
}

model Payment {
  id              Int           @id @default(autoincrement())
  saleId          Int
  method          PaymentMethod
  amount          Decimal       @db.Decimal(10, 2)
  referenceNumber String?
  // For card/UPI tenders: bank or account name, captured for reconciliation.
  identifier      String?
  status          PaymentStatus @default(completed)
  createdAt       DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id])

  @@map("payments")
}

// ─── Returns ─────────────────────────────────────────

enum ReturnType {
  return
  exchange
}

enum ReturnStatus {
  pending
  approved
  completed
}

model Return {
  id             Int          @id @default(autoincrement())
  originalSaleId Int
  branchId       Int
  userId         Int
  returnNumber   String       @unique
  type           ReturnType
  reason         String?
  subtotal       Decimal      @db.Decimal(10, 2)
  taxAmount      Decimal      @db.Decimal(10, 2)
  total          Decimal      @db.Decimal(10, 2)
  status         ReturnStatus @default(pending)
  // How the refund was settled. `proportional` (default) mirrors the original
  // payment split (card→card, points→wallet); an override forces a single
  // method and requires manager approval (recorded in `approvedBy` + audit log).
  refundMode            String   @default("proportional")
  // Per-method cash/card/upi refund breakup: [{ method, amount }]. Loyalty is
  // tracked separately in the points columns below (it's not a cash tender).
  refundBreakup         Json?
  loyaltyPointsRestored Int      @default(0) // redeemed points returned to wallet
  loyaltyPointsReversed Int      @default(0) // earned points clawed back
  approvedBy            Int?     // manager/owner who authorised a method override
  createdAt      DateTime     @default(now())

  originalSale Sale         @relation(fields: [originalSaleId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  items        ReturnItem[]

  @@map("returns")
}

enum ItemCondition {
  resellable
  damaged
}

model ReturnItem {
  id         Int           @id @default(autoincrement())
  returnId   Int
  saleItemId Int
  variantId  Int
  quantity   Int
  unitPrice  Decimal       @db.Decimal(10, 2)
  condition  ItemCondition @default(resellable)

  returnRecord Return         @relation(fields: [returnId], references: [id])
  saleItem     SaleItem       @relation(fields: [saleItemId], references: [id])
  variant      ProductVariant @relation(fields: [variantId], references: [id])

  @@map("return_items")
}

// ─── POS Session ─────────────────────────────────────

enum SessionStatus {
  open
  closed
}

model PosSession {
  id             Int           @id @default(autoincrement())
  branchId       Int
  userId         Int
  openingAmount  Decimal       @db.Decimal(10, 2)
  closingAmount  Decimal?      @db.Decimal(10, 2)  // physical cash counted at close
  expectedAmount Decimal?      @db.Decimal(10, 2)
  // §8 EOD reconciliation breakdown.
  pettyCash       Decimal? @default(0) @db.Decimal(10, 2)
  pettyCashReason String?
  cashDrop        Decimal? @default(0) @db.Decimal(10, 2)
  variance        Decimal? @db.Decimal(10, 2)
  varianceReason  String?
  status         SessionStatus @default(open)
  openedAt       DateTime      @default(now())
  closedAt       DateTime?
  notes          String?

  branch Branch @relation(fields: [branchId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("pos_sessions")
}

model HeldTransaction {
  id         Int      @id @default(autoincrement())
  branchId   Int
  userId     Int
  cartData   Json
  customerId Int?
  notes      String?
  createdAt  DateTime @default(now())
  // §4.4 — holds auto-expire (default 24h). Expired holds drop off the active
  // list on the next read (released/archived).
  expiresAt  DateTime?

  branch   Branch    @relation(fields: [branchId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("held_transactions")
}

// Monotonic per-channel counter for human-friendly bill numbers (W-0001, O-0001).
// `key` is the stable channel ("walkin"/"online") so editing the display prefix in
// Settings never resets the running count. Incremented atomically inside checkout.
model BillSequence {
  key        String   @id
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@map("bill_sequences")
}

// ─── Customer & Loyalty ──────────────────────────────

enum LoyaltyTier {
  bronze
  silver
  gold
  platinum
}

model Customer {
  id           Int        @id @default(autoincrement())
  firstName    String
  lastName     String?
  phone        String     @unique
  email        String?
  address      String?
  // §5.3 — DOB drives birthday insights/marketing; gender ('M'/'F') drives
  // clothing-category suggestions + size prediction. Nullable so legacy rows
  // (and the quick walk-in add) survive; the POS prompts to fill them (§5.4).
  dateOfBirth  DateTime?
  gender       String?
  loyaltyPoints Int       @default(0)
  loyaltyTier  LoyaltyTier @default(bronze)
  totalSpent   Decimal    @default(0) @db.Decimal(12, 2)
  visitCount   Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  sales              Sale[]
  heldTransactions   HeldTransaction[]
  loyaltyTransactions LoyaltyTransaction[]
  messageLogs        MessageLog[]
  upiPaymentIntents  UpiPaymentIntent[]
  giftVouchers       GiftVoucher[]

  @@map("customers")
}

enum LoyaltyTxType {
  earned
  redeemed
  adjusted
  expired
}

model LoyaltyTransaction {
  id          Int          @id @default(autoincrement())
  customerId  Int
  saleId      Int?
  points      Int
  type        LoyaltyTxType
  description String?
  createdAt   DateTime     @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  sale     Sale?    @relation(fields: [saleId], references: [id])

  @@map("loyalty_transactions")
}

model LoyaltyConfig {
  id                 Int  @id @default(autoincrement())
  pointsPerAmount    Int  @default(1)
  amountPerPoint     Int  @default(100)
  redemptionValue    Decimal @default(1) @db.Decimal(10, 2)
  minRedeemPoints    Int  @default(100)
  tierThresholds     Json @default("{\"silver\": 1000, \"gold\": 5000, \"platinum\": 20000}")
  earningMultipliers Json @default("{\"bronze\": 1, \"silver\": 1.5, \"gold\": 2, \"platinum\": 3}")

  @@map("loyalty_config")
}

// ─── Accounting ──────────────────────────────────────

enum AccType {
  asset
  liability
  equity
  revenue
  expense
}

model Account {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  type      AccType
  parentId  Int?
  isSystem  Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  parent       Account?      @relation("AccountTree", fields: [parentId], references: [id])
  children     Account[]     @relation("AccountTree")
  journalLines JournalLine[]
  expenseCategories ExpenseCategory[]

  @@map("accounts")
}

model JournalEntry {
  id            Int      @id @default(autoincrement())
  branchId      Int
  entryNumber   String   @unique
  date          DateTime
  description   String
  referenceType String?
  referenceId   Int?
  createdBy     Int
  createdAt     DateTime @default(now())

  branch Branch        @relation(fields: [branchId], references: [id])
  user   User          @relation(fields: [createdBy], references: [id])
  lines  JournalLine[]

  @@index([branchId, date])
  @@map("journal_entries")
}

model JournalLine {
  id          Int     @id @default(autoincrement())
  entryId     Int
  accountId   Int
  debit       Decimal @default(0) @db.Decimal(12, 2)
  credit      Decimal @default(0) @db.Decimal(12, 2)
  description String?

  entry   JournalEntry @relation(fields: [entryId], references: [id])
  account Account      @relation(fields: [accountId], references: [id])

  @@map("journal_lines")
}

// ─── Expenses ────────────────────────────────────────

enum ExpStatus {
  pending
  approved
  rejected
}

model Expense {
  id            Int       @id @default(autoincrement())
  branchId      Int
  categoryId    Int
  amount        Decimal   @db.Decimal(10, 2)
  description   String
  date          DateTime
  paymentMethod String
  receiptUrl    String?
  status        ExpStatus @default(pending)
  createdBy     Int
  approvedBy    Int?
  createdAt     DateTime  @default(now())

  branch   Branch          @relation(fields: [branchId], references: [id])
  category ExpenseCategory @relation(fields: [categoryId], references: [id])
  creator  User            @relation("ExpenseCreator", fields: [createdBy], references: [id])
  approver User?           @relation("ExpenseApprover", fields: [approvedBy], references: [id])

  @@map("expenses")
}

model ExpenseCategory {
  id        Int      @id @default(autoincrement())
  name      String
  accountId Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  account  Account?  @relation(fields: [accountId], references: [id])
  expenses Expense[]

  @@map("expense_categories")
}

// ─── Employee Management ─────────────────────────────

model Attendance {
  id          Int       @id @default(autoincrement())
  userId      Int
  branchId    Int
  clockIn     DateTime
  clockOut    DateTime?
  hoursWorked Decimal?  @db.Decimal(5, 2)
  date        DateTime  @db.Date
  createdAt   DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id])
  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([userId, date])
  @@map("attendance")
}

enum CommStatus {
  pending
  paid
}

model Commission {
  id             Int        @id @default(autoincrement())
  userId         Int
  saleId         Int
  amount         Decimal    @db.Decimal(10, 2)
  rate           Decimal    @db.Decimal(5, 2)
  status         CommStatus @default(pending)
  payPeriodStart DateTime   @db.Date
  payPeriodEnd   DateTime   @db.Date
  createdAt      DateTime   @default(now())

  user User @relation(fields: [userId], references: [id])
  sale Sale @relation(fields: [saleId], references: [id])

  @@map("commissions")
}

// ─── Messaging ───────────────────────────────────────

enum MsgType {
  whatsapp
  sms
}

enum MsgStatus {
  pending
  sent
  delivered
  failed
}

model MessageLog {
  id               Int       @id @default(autoincrement())
  customerId       Int
  type             MsgType
  template         String
  payload          Json
  status           MsgStatus @default(pending)
  providerResponse Json?
  createdAt        DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("message_logs")
}

// ─── UPI Payment Intents ────────────────────────────

model UpiPaymentIntent {
  id               Int      @id @default(autoincrement())
  intentId         String   @unique
  providerOrderId  String
  provider         String   @default("cashfree")
  branchId         Int
  userId           Int
  amount           Decimal  @db.Decimal(10, 2)
  status           String   @default("pending")
  qrCodeUrl        String   @db.Text
  upiLink          String   @db.Text
  utrNumber        String?
  saleId           Int?     @unique
  cartSnapshot     Json
  customerId       Int?
  discountAmount   Decimal  @default(0) @db.Decimal(10, 2)
  expiresAt        DateTime
  completedAt      DateTime?
  createdAt        DateTime @default(now())

  branch           Branch   @relation(fields: [branchId], references: [id])
  user             User     @relation(fields: [userId], references: [id])
  sale             Sale?    @relation(fields: [saleId], references: [id])
  customer         Customer? @relation(fields: [customerId], references: [id])

  @@index([status, expiresAt])
  @@map("upi_payment_intents")
}
