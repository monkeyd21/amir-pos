# ─── Production env for the Oracle VPS ───────────────────────────────
# Copy to /opt/amir-pos/backend/.env on the server and fill in real values.
# Generate the JWT secrets with:  openssl rand -hex 48

# Local Postgres on the same box (see DEPLOY-ORACLE.md for DB/user setup)
DATABASE_URL="postgresql://amir:CHANGE_ME_DB_PASSWORD@localhost:5432/amir_pos?schema=public"

PORT=3000
NODE_ENV=production

# Public URL the app is served from (used for CORS/links). Your domain over HTTPS.
FRONTEND_URL=https://pos.example.com

JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_48
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_openssl_rand_hex_48
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

APP_NAME=Sabiha's Ethnic
DEFAULT_CURRENCY=INR
DEFAULT_TAX_RATE=18

# Optional — WhatsApp Graph API (leave blank if unused)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
